DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ultravet?schema=public"
AUTH_SECRET="replace-with-a-secure-random-string"
AUTH_URL="http://localhost:3000"

# Local development default. For Vercel preview/production use object storage.
UPLOAD_DRIVER="local"
UPLOAD_LOCAL_DIR="./uploads"

# Required only when UPLOAD_DRIVER="s3"
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="false"
